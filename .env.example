NODE_ENV=development
PORT=3000
DATABASE_URL=postgres://accesscore:accesscore@localhost:5432/accesscore
REDIS_URL=redis://localhost:6379

# Token signing. `vault` uses HashiCorp Vault Transit (non-exportable keys, ADR-009);
# `software` uses an in-process Ed25519 key for offline dev/tests only.
SIGNER_DRIVER=vault
VAULT_ADDR=http://localhost:8200
VAULT_TOKEN=accesscore-dev-token
VAULT_TRANSIT_KEY=accesscore-signing
