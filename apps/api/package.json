{
  "name": "@accesscore/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "seed": "nest build && node dist/seed.js",
    "lint": "eslint \"src/**/*.ts\" \"test/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json --runInBand",
    "test:int": "jest --config ./test/jest-integration.json --runInBand",
    "test:cov": "jest --coverage",
    "test:int:cov": "jest --config ./test/jest-integration.json --runInBand --coverage",
    "test:e2e:cov": "jest --config ./test/jest-e2e.json --runInBand --coverage",
    "coverage": "rm -rf coverage .nyc_output && pnpm run test:cov && pnpm run test:int:cov && pnpm run test:e2e:cov && mkdir -p .nyc_output && cp coverage/unit/coverage-final.json .nyc_output/unit.json && cp coverage/int/coverage-final.json .nyc_output/int.json && cp coverage/e2e/coverage-final.json .nyc_output/e2e.json && nyc report && nyc check-coverage",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.4.5",
    "@nestjs/throttler": "^6.5.0",
    "@scalar/nestjs-api-reference": "^1.2.9",
    "argon2": "^0.45.0",
    "drizzle-orm": "^0.38.3",
    "helmet": "^8.3.0",
    "ioredis": "^5.11.1",
    "nestjs-pino": "^4.6.1",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "prom-client": "^15.1.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "drizzle-kit": "^0.30.1",
    "fast-check": "^4.9.0",
    "jest": "^29.7.0",
    "nyc": "^18.0.0",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
